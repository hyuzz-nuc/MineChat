{
  "name": "minechat-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "MineChat - 沉浸式暗色聊天软件桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:dev": "cross-env MINECHAT_DEV=1 electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {},
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.minechat.desktop",
    "productName": "MineChat",
    "directories": {
      "output": "../release"
    },
    "files": [
      "main.js",
      "preload.js",
      "../client/dist/**/*",
      "../server/dist/**/*",
      "../server/prisma/**/*",
      "../server/node_modules/**/*",
      "../server/package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "../build/icon.ico",
      "artifactName": "MineChat-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "../build/icon.ico",
      "uninstallerIcon": "../build/icon.ico",
      "installerHeaderIcon": "../build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "shortcutName": "MineChat"
    },
    "mac": {
      "target": "dmg",
      "icon": "../build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "../build/icon.png"
    },
    "extraResources": [
      {
        "from": "../server/dist",
        "to": "server/dist"
      },
      {
        "from": "../server/prisma",
        "to": "server/prisma"
      },
      {
        "from": "../server/node_modules",
        "to": "server/node_modules"
      },
      {
        "from": "../server/package.json",
        "to": "server/package.json"
      }
    ]
  }
}
